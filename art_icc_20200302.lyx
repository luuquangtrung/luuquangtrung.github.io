\begin_layout Subsection
Rate Function
\begin_inset CommandInset label
LatexCommand label
name "subsec:Rate-Allocation-Model"

\end_inset


\end_layout

\begin_layout Standard
The amount of data carried by a RB for a user located in 
\begin_inset Formula $\mathcal{A}_{q}^{\sigma}$
\end_inset

 and served by a RRH in 
\begin_inset Formula $x_{i}^{\textrm{r}}$
\end_inset

 is 
\begin_inset Formula $b_{\textrm{d}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 and 
\begin_inset Formula $b_{\textrm{u}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

, respectively for DL and UL.
 Models for 
\begin_inset Formula $b_{\textrm{d}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 and 
\begin_inset Formula $b_{\textrm{u}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 are now considered.
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $d\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 be the distance between 
\begin_inset Formula $x_{i}^{\textrm{r}}$
\end_inset

 and the center of each rectangle 
\begin_inset Formula $\mathcal{A}_{q}^{\sigma}$
\end_inset

.
 Focusing on DL traffic, one considers the following model taken from 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
cite{Tse2004}
\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
b_{\textrm{d}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)=W_{i}\log_{2}\left(1+SNR_{\text{d}}\left(i,q\right)\right),\label{eq:Bd}
\end{equation}

\end_inset

where 
\begin_inset Formula $W_{i}$
\end_inset

 is the bandwidth (in Hz) of a RB provided by RRH
\begin_inset space ~
\end_inset


\begin_inset Formula $i$
\end_inset

.
 
\begin_inset Formula $SNR_{\text{d}}\left(i,q\right)$
\end_inset

 is the DL Signal-to-Noise (SNR) ratio from RRH 
\begin_inset Formula $i$
\end_inset

 to users located in subarea 
\begin_inset Formula $q$
\end_inset

, given by 
\begin_inset Formula $SNR_{\text{d}}\left(i,q\right)=P_{\text{rx,d}}\left(d\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)\right)/P_{\text{n}}$
\end_inset

, where 
\begin_inset Formula $P_{\text{n}}=W_{i}N_{0}$
\end_inset

 is the noise power, 
\begin_inset Formula $N_{0}$
\end_inset

 is the noise power spectral density.
 
\begin_inset Formula $P_{\text{rx}}(d)=P_{\text{tx,d}}+G_{\text{tx,d}}+G_{\text{rx,d}}-PL(d)$
\end_inset

 is the signal power at the receiver, where 
\begin_inset Formula $P_{\text{tx}}$
\end_inset

 is the transmission power of the transmitter, 
\begin_inset Formula $G_{\text{tx}}$
\end_inset

 and 
\begin_inset Formula $G_{\text{rx}}$
\end_inset

 are the antenna gains of the transmitter and the receiver.
 
\begin_inset Formula $PL(d)=10\alpha\log_{10}(d)+\beta+10\gamma\log_{10}(f_{i})$
\end_inset

 is the path loss given by the adapted 
\begin_inset Formula $\alpha\beta\gamma$
\end_inset

-model introduced in 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
cite{Sun2016a}
\end_layout

\end_inset

 for 5G mobile networks, where 
\begin_inset Formula $\alpha$
\end_inset

 and 
\begin_inset Formula $\gamma$
\end_inset

 are respectively coefficients accounting for the dependency of the path
 loss with distance and frequency 
\begin_inset Formula $f_{i}$
\end_inset

, 
\begin_inset Formula $β$
\end_inset

 is an optimized offset value for path loss (in dB).
 The model 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Bd"

\end_inset

 is also considered for 
\begin_inset Formula $b_{\textrm{u}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

.
\end_layout

\begin_layout Standard
A heterogeneous cellular network is considered.
 The RRHs 4, 5, 7, and 8 are microcells, whereas the rest are macrocells.
 The parameters for the models 
\begin_inset Formula $b_{\textrm{d}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 and 
\begin_inset Formula $b_{\textrm{u}}\left(x_{i}^{\textrm{r}},\mathcal{A}_{q}^{\sigma}\right)$
\end_inset

 are: 
\begin_inset Formula $a_{\textrm{r}}(i)=100$
\end_inset

, 
\begin_inset Formula $f_{i}=2.6$
\end_inset

 GHz, 
\begin_inset Formula $W_{i}=0.2$
\end_inset


\begin_inset space ~
\end_inset

MHz, 
\begin_inset Formula $\left(P_{\text{tx,d}},P_{\text{tx,u}}\right)=\left(43,12\right)$
\end_inset


\begin_inset space ~
\end_inset

dBm for macrocells and 
\begin_inset Formula $\left(P_{\text{tx,d}},P_{\text{tx,u}}\right)=\left(35,8\right)$
\end_inset


\begin_inset space ~
\end_inset

dBm for microcells, 
\begin_inset Formula $\left(G_{\text{tx,d}},G_{\text{tx,u}}\right)=\left(15,3\right)$
\end_inset


\begin_inset space ~
\end_inset

dBi, 
\begin_inset Formula $N_{0}=-174$
\end_inset


\begin_inset space ~
\end_inset

dBm/Hz, and 
\begin_inset Formula $\left(\alpha,\beta,\gamma\right)=\left(3.6,7.6,2\right)$
\end_inset

, see 
\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
cite{ETSI2016}
\end_layout

\end_inset

.
 Moreover, 
\family roman
\series medium
\shape up
\size normal
\emph off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
