\emph default
\bar default
\strikeout default
\xout default
\uuline default
\uwave default
\noun default
\color inherit

\begin_inset Formula $c_{\text{r}}$
\end_inset

, 
\begin_inset Formula $\lambda$
\end_inset

, are set to 
\begin_inset Formula $100$
\end_inset

, 
\begin_inset Formula $1$
\end_inset

, and 
\begin_inset Formula $0.1$
\end_inset

 in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Cover_Cost_Single"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Cover_Cost_Multi"

\end_inset

.
 The offset considered in the Baseline algorithm is set to 
